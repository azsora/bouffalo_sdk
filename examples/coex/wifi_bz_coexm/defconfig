-include $(BL_SDK_BASE)/examples/wifi/defconfig

CONFIG_MBEDTLS_AES_USE_HW    =y
CONFIG_MBEDTLS_BIGNUM_USE_HW =y
CONFIG_MBEDTLS_ECC_USE_HW    =y
CONFIG_MBEDTLS_SHA1_USE_HW   =y
CONFIG_MBEDTLS_SHA256_USE_HW =y
CONFIG_MBEDTLS_SHA512_USE_HW =y

CONFIG_WIFI_IPERF=y

ifeq ($(CHIP),bl618dg)
    CONFIG_ROMAPI             =n
    CONFIG_DUALCORE_DISABLE   =y
    CONFIG_BT_PATH            =y
endif


# ============ BT ============
CONFIG_BLUETOOTH =y
CONFIG_RF =y
CONFIG_BLE_USE_MAC2 =n

ifeq ($(CHIP),bl618dg)
    CONFIG_BTBLECONTROLLER_LIB =ble1m2s1bredr1
    CONFIG_BT_BREDR =y
    CONFIG_BT_A2DP =y
    CONFIG_BT_SPP =y
    CONFIG_BT_A2DP_SOURCE =n
    CONFIG_BT_AVRCP =y
    CONFIG_BT_HFP =y
    CONFIG_BT_TP_CLI =y
else ifeq ($(CHIP),bl616cl)
    # bl616cl is BLE-only (no classic BT / mesh)
    CONFIG_BTBLECONTROLLER_LIB =m2s1
else
    CONFIG_BTBLECONTROLLER_LIB =ble1m10s1bredr0
endif

ifeq ($(CHIP),bl618dg)
    CONFIG_LITTLEFS =n
    CONFIG_BFLB_MTD =n
    CONFIG_PARTITION =n
    CONFIG_BT_SETTINGS =n
else
    CONFIG_LITTLEFS =y
    CONFIG_BFLB_MTD =y
    CONFIG_PARTITION =y
    CONFIG_BT_SETTINGS =y
endif
CONFIG_BT_STACK_CLI =y
